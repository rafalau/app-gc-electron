{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "install-app-deps": "electron-builder install-app-deps",
    "build:unpack": "npm run build && npm run install-app-deps && electron-builder --dir",
    "build:win": "npm run build && npm run install-app-deps && electron-builder --win",
    "build:mac": "npm run build && npm run install-app-deps && electron-builder --mac",
    "build:linux": "npm run build && npm run install-app-deps && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "electron-store": "^11.0.2",
    "tailwindcss": "^4.2.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@rushstack/eslint-patch": "^1.7.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "electron": "41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.2.4",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  }
}
